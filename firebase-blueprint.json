{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "A user who has subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "subscribedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user subscribed."
        },
        "status": {
          "type": "string",
          "enum": ["active", "unsubscribed"],
          "description": "The subscription status."
        }
      },
      "required": ["email", "subscribedAt", "status"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "A fitness program enrollment application.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "program": { "type": "string" },
        "schedule": { "type": "string" },
        "coach": { "type": "string" },
        "goals": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "mobileNumber", "email", "program", "schedule", "submittedAt"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the North Fitness Camp.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A personal training session booking.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timeSlot": { "type": "string" },
        "coachId": { "type": "string" },
        "coachName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "mobileNumber", "date", "timeSlot", "coachId", "status", "createdAt"]
    },
    "Coach": {
      "title": "Coach",
      "description": "A fitness coach at North Fitness Camp.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "exp": { "type": "string" },
        "gender": { "type": "string" },
        "image": { "type": "string" },
        "offer": { "type": "string" },
        "quote": { "type": "string" },
        "funFact": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "title", "gender", "image", "order"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/subscribers/{email}": {
      "schema": "Subscriber",
      "description": "Collection of newsletter subscribers."
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Collection of program enrollment applications."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of session bookings."
    },
    "/coaches/{coachId}": {
      "schema": "Coach",
      "description": "Collection of coach profiles."
    }
  }
}
